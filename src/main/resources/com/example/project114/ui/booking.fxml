<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="360.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project114.bookingController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" styleClass="app-background">
         <children>
            <BorderPane prefHeight="80.0" prefWidth="360.0">
               <center>
                  <Label alignment="CENTER" styleClass="book-table-title" text="Book a Table" BorderPane.alignment="CENTER">
                     <BorderPane.margin>
                        <Insets right="60.0" top="10.0" />
                     </BorderPane.margin>
                  </Label>
               </center>
               <left>
                  <ImageView fitHeight="13.0" fitWidth="13.0" onMouseClicked="#goToUserLogin" pickOnBounds="true" preserveRatio="true" styleClass="back-btn" BorderPane.alignment="CENTER">
                     <image>
                        <Image url="@../style/img/arrow.png" />
                     </image>
                     <BorderPane.margin>
                        <Insets left="20.0" top="10.0" />
                     </BorderPane.margin>
                  </ImageView>
               </left>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </BorderPane>
            <HBox prefHeight="80.0" prefWidth="300.0" spacing="10.0" styleClass="info-box">
               <children>
                  <ImageView fitHeight="30.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../style/img/pers-icon.png" />
                     </image>
                     <HBox.margin>
                        <Insets left="15.0" top="25.0" />
                     </HBox.margin>
                  </ImageView>
                  <VBox prefHeight="100.0" prefWidth="240.0">
                     <children>
                        <Label fx:id="name" prefHeight="18.0" prefWidth="186.0" styleClass="name" text="Name">
                           <VBox.margin>
                              <Insets top="23.0" />
                           </VBox.margin>
                        </Label>
                        <Label fx:id="tel" prefHeight="18.0" prefWidth="200.0" styleClass="tel" text="Tel." />
                     </children>
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" top="30.0" />
               </VBox.margin>
            </HBox>
            <HBox prefHeight="30.0" prefWidth="320.0" spacing="5.0">
               <children>
                  <ImageView fitHeight="15.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../style/img/date.png" />
                     </image>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </ImageView>
                  <Label styleClass="text-label" text="Date &amp;Time" />
               </children>
               <VBox.margin>
                  <Insets left="40.0" right="40.0" top="30.0" />
               </VBox.margin>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </HBox>
            <VBox prefHeight="50.0" prefWidth="300.0" styleClass="date-box">
               <children>
                  <HBox prefHeight="50.0" prefWidth="300.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="26.0" prefWidth="60.0" styleClass="text-label" text="Date" />
                        <DatePicker id="datePicker" fx:id="datePicker" focusTraversable="false" prefHeight="25.0" prefWidth="210.0" styleClass="modern-datepicker" />
                     </children>
                     <padding>
                        <Insets top="10.0" />
                     </padding>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets left="30.0" right="30.0" top="10.0" />
               </VBox.margin>
            </VBox>
            <BorderPane prefHeight="100.0" prefWidth="360.0">
               <right>
                  <VBox prefHeight="100.0" prefWidth="150.0" BorderPane.alignment="CENTER">
                     <children>
                        <Label prefHeight="18.0" prefWidth="150.0" styleClass="text-label" text="Booked / All tables">
                           <VBox.margin>
                              <Insets left="10.0" />
                           </VBox.margin>
                        </Label>
                        <VBox fx:id="bookedBox" prefHeight="40.0" prefWidth="150.0" styleClass="no-booked-box">
                           <VBox.margin>
                              <Insets right="30.0" top="10.0" />
                           </VBox.margin>
                           <children>
                              <Label fx:id="booked" alignment="CENTER" prefHeight="40.0" prefWidth="120.0" styleClass="booked" text="0/10" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </right>
               <left>
                  <VBox prefHeight="100.0" prefWidth="150.0" BorderPane.alignment="CENTER">
                     <children>
                        <Label alignment="CENTER" prefHeight="18.0" prefWidth="150.0" styleClass="text-label" text="Time">
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                        </Label>
                        <ComboBox fx:id="timeChoice" prefHeight="40.0" prefWidth="120.0" styleClass="combo-box" visibleRowCount="7">
                           <VBox.margin>
                              <Insets left="30.0" top="10.0" />
                           </VBox.margin>
                           <padding>
                              <Insets left="20.0" />
                           </padding>
                        </ComboBox>
                     </children>
                  </VBox>
               </left>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <bottom>
                  <Label text="Note: Each table is limited to 1 hour and 30 minutes." BorderPane.alignment="CENTER">
                     <font>
                        <Font size="11.0" />
                     </font>
                  </Label>
               </bottom>
            </BorderPane>
            <HBox prefHeight="30.0" prefWidth="320.0" spacing="5.0">
               <children>
                  <ImageView fitHeight="15.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../style/img/Vector-2.png" />
                     </image>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </ImageView>
                  <Label styleClass="text-label" text="Guest" />
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
               <VBox.margin>
                  <Insets left="40.0" right="40.0" top="30.0" />
               </VBox.margin>
            </HBox>
            <BorderPane prefHeight="80.0" prefWidth="300.0" styleClass="guest-box">
               <VBox.margin>
                  <Insets left="30.0" right="30.0" top="10.0" />
               </VBox.margin>
               <left>
                  <ImageView fitHeight="40.0" fitWidth="40.0" onMouseClicked="#onClickReduce" pickOnBounds="true" preserveRatio="true" styleClass="reduce-guest-btn" BorderPane.alignment="CENTER">
                     <image>
                        <Image url="@../style/img/btn_m.png" />
                     </image>
                     <BorderPane.margin>
                        <Insets left="20.0" />
                     </BorderPane.margin>
                  </ImageView>
               </left>
               <right>
                  <ImageView fitHeight="40.0" fitWidth="40.0" onMouseClicked="#onClickPlus" pickOnBounds="true" preserveRatio="true" styleClass="add-guest-btn" BorderPane.alignment="CENTER">
                     <BorderPane.margin>
                        <Insets right="20.0" />
                     </BorderPane.margin>
                     <image>
                        <Image url="@../style/img/btn_plus.png" />
                     </image>
                  </ImageView>
               </right>
               <center>
                  <Label fx:id="guestNo" styleClass="text-label" text="1 Guest" BorderPane.alignment="CENTER">
                     <font>
                        <Font size="14.0" />
                     </font></Label>
               </center>
            </BorderPane>
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="240.0" styleClass="confirm-btn-box">
               <children>
                  <Button fx:id="confirm" mnemonicParsing="false" onMouseClicked="#confirmSubmit" prefHeight="50.0" prefWidth="240.0" text="Confirm">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets left="60.0" right="60.0" top="30.0" />
               </VBox.margin>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
