<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="360.0" styleClass="app-background" stylesheets="@../style/success.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.theerayut.app.controller.successController">
   <children>
      <AnchorPane prefHeight="800.0" prefWidth="360.0">
         <children>
            <VBox alignment="TOP_LEFT" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <padding>
                  <Insets bottom="22.0" left="22.0" right="22.0" top="85.0" />
               </padding>
               <children>
                  <!-- hero card -->
                  <VBox alignment="TOP_CENTER" styleClass="soft-card">
                     <padding>
                        <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
                     </padding>
                     <children>
                        <StackPane fx:id="container" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="90.0" prefWidth="90.0" styleClass="badge-ring">
                           <children>
                              <StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="65.0" prefWidth="65.0" styleClass="badge-core">
                                 <children>
                                    <SVGPath content="M4 12 L9 17 L20 6" fill="TRANSPARENT" scaleX="1.2" scaleY="1.2" stroke="WHITE" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="3.0" />
                                 </children>
                              </StackPane>
                           </children>
                        </StackPane>
                        <Label styleClass="confirm-title" text="Booking confirmed">
                           <VBox.margin>
                              <Insets top="14.0" />
                           </VBox.margin>
                        </Label>
                        <Label alignment="CENTER" styleClass="confirm-sub" text="Your table is reserved. See you soon!" wrapText="true">
                           <VBox.margin>
                              <Insets top="6.0" />
                           </VBox.margin>
                        </Label>
                     </children>
                  </VBox>
                  <!-- details card -->
                  <VBox fx:id="detailBox" spacing="13.0" styleClass="soft-card">
                     <padding>
                        <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
                     </padding>
                     <VBox.margin>
                        <Insets top="12.0" />
                     </VBox.margin>
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="row-label" text="Name" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="name" styleClass="row-value" text="name" />
                           </children>
                        </HBox>
                        <Region prefHeight="1.0" styleClass="row-divider" />
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="row-label" text="Date" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="date" styleClass="row-value" text="00/00/00" />
                           </children>
                        </HBox>
                        <Region prefHeight="1.0" styleClass="row-divider" />
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="row-label" text="Time" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="time" styleClass="row-value" text="00:00" />
                           </children>
                        </HBox>
                        <Region prefHeight="1.0" styleClass="row-divider" />
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="row-label" text="Guests" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="guestNo" styleClass="row-value" text="0" />
                           </children>
                        </HBox>
                        <Region prefHeight="1.0" styleClass="row-divider" />
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label styleClass="row-label" text="Table" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="table" styleClass="table-chip" text="T0" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Region VBox.vgrow="ALWAYS" />
                  <!-- done button -->
                  <Button fx:id="doneBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#doneOnClicked" prefHeight="52.0" text="Done" />
               </children>
            </VBox>
            <!-- back button (floating, like menuBtn on booking) -->
            <VBox fx:id="backBtnBox" alignment="CENTER" layoutX="18.0" layoutY="25.0" onMouseClicked="#goToBooking" prefHeight="45.0" prefWidth="45.0" styleClass="back-btn">
               <children>
                  <ImageView fx:id="icon" fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../style/img/triangle.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
         </children>
      </AnchorPane>
      <AnchorPane fx:id="confettiPane" mouseTransparent="true" prefHeight="800.0" prefWidth="360.0" visible="false" />
   </children>
</StackPane>
